{
  "name": "@memory-match/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply memory-match-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply memory-match-db --remote"
  },
  "dependencies": {
    "@memory-match/shared": "workspace:*",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
