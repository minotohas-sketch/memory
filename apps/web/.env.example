# Copie ce fichier en ".env.local" pour surcharger ces valeurs en local.

# URL de l'API (backend Worker)
VITE_API_BASE_URL=http://localhost:8787

# Username du bot (@BotFather) et short name du Mini App (/newapp), sans le @
# ni le / — utilisés pour construire le lien de parrainage partageable.
VITE_TELEGRAM_BOT_USERNAME=your_bot
VITE_TELEGRAM_APP_SHORTNAME=app

# Block IDs Adsgram (partner.adsgram.ai) — 4 blocs distincts à créer :
#   - energy_refill et bonus_coins sont deux blocs de type Reward (format numérique brut, ex: "123")
#   - interstitial est un bloc Interstitial (format "int-xxx")
#   - task est LE SEUL bloc Task autorisé par compte (format "task-xxx")
# Voir le README (section Phase 4) pour la Reward URL à configurer sur chacun.
VITE_ADSGRAM_ENERGY_BLOCK_ID=
VITE_ADSGRAM_BONUS_BLOCK_ID=
VITE_ADSGRAM_INTERSTITIAL_BLOCK_ID=
VITE_ADSGRAM_TASK_BLOCK_ID=
